import os
import pickle
from abc import ABC, abstractmethod


class User(ABC):

    def __init__(self, name):
        self._name = name

    @abstractmethod
    def show_info(self):
        pass


class Librarian(User):

    def show_info(self):
        print(f"Библиотекарь: {self._name}")


class Member(User):

    def __init__(self, name, borrowed_books=None):
        super().__init__(name)
        if borrowed_books is None:
            self.borrowed_books = []
        else:
            self.borrowed_books = borrowed_books

    def show_info(self):
        if self.borrowed_books:
            books = ", ".join(self.borrowed_books)
        else:
            books = "нет"
        print(f"Пользователь: {self._name}, Книги: {books}")


class Library:

    def __init__(self):
        self.books = []
        self.members = []
        self.librarians = []
        self.load_data()

    def load_data(self):
        if os.path.exists("library_data.pkl"):
            with open("library_data.pkl", "rb") as f:
                data = pickle.load(f)
                self.books = data["books"]
                self.members = data["members"]
                self.librarians = data["librarians"]
            print("Данные загружены из library_data.pkl")

    def save_data(self):
        data = {
            "books": self.books,
            "members": self.members,
            "librarians": self.librarians
        }
        with open("library_data.pkl", "wb") as f:
            pickle.dump(data, f)
        print("Данные сохранены в library_data.pkl")

    def add_book(self):
        name = input("Название: ")
        author = input("Автор: ")
        self.books.append({"name": name, "author": author, "status": "доступна"})
        print("Книга добавлена.")

    def remove_book(self):
        title = input("Название для удаления: ")
        for book in self.books:
            if book["name"] == title:
                self.books.remove(book)
                print("Книга удалена.")
                return
        print("Книга не найдена.")

    def register_member(self):
        name = input("Имя пользователя: ")
        self.members.append(Member(name))
        print("Пользователь зарегистрирован.")

    def show_all_members(self):
        for m in self.members:
            m.show_info()

    def show_all_books(self):
        for b in self.books:
            print(f"{b['name']} — {b['author']} [{b['status']}]")

    def show_available_books(self):
        for b in self.books:
            if b["status"] == "доступна":
                print(f"{b['name']} — {b['author']}")

    def find_member(self, name):
        for m in self.members:
            if m._name == name:
                return m
        return None

    def take_book(self, user):
        title = input("Название книги: ")
        for book in self.books:
            if book["name"] == title:
                if book["status"] == "доступна":
                    book["status"] = "выдана"
                    user.borrowed_books.append(title)
                    print("Книга взята.")
                else:
                    print("Книга уже занята.")
                return
        print("Книга не найдена.")

    def return_book(self, user):
        title = input("Название книги: ")
        if title in user.borrowed_books:
            for book in self.books:
                if book["name"] == title:
                    book["status"] = "доступна"
            user.borrowed_books.remove(title)
            print("Книга возвращена.")
        else:
            print("У вас нет такой книги.")


library = Library()

while True:
    print("\n1-Библиотекарь, 2-Пользователь, 0-Выход")
    role = input("Выберите роль: ")

    if role == "0":
        library.save_data()
        break

    elif role == "1":
        print("\n[Меню библиотекаря]")
        act = input("1-Добавить книгу, 2-Удалить книгу, 3-Рег. юзера, 4-Все юзеры, 5-Все книги: ")
        if act == "1":
            library.add_book()
        elif act == "2":
            library.remove_book()
        elif act == "3":
            library.register_member()
        elif act == "4":
            library.show_all_members()
        elif act == "5":
            library.show_all_books()

    elif role == "2":
        name = input("Введите ваше имя: ")
        current_user = library.find_member(name)
        if current_user:
            print("\n[Меню пользователя]")
            act = input("1-Доступные книги, 2-Взять, 3-Вернуть, 4-Мои книги: ")
            if act == "1":
                library.show_available_books()
            elif act == "2":
                library.take_book(current_user)
            elif act == "3":
                library.return_book(current_user)
            elif act == "4":
                current_user.show_info()
        else:
            print("Пользователь не найден.")
